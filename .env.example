# Copy this file to `.env` (same directory) and paste your real keys in.
# `.env` is gitignored — never commit it, and never paste keys into chat.

# Required for the real SWE-bench evaluation (scripts 07 and 08).
# Create one at https://app.daytona.io/dashboard/keys
DAYTONA_API_KEY=

# Required only for the real code-fix agent (script 08) and the optional
# LLM paraphrase perturbations. Not needed for the free smoke test.
ANTHROPIC_API_KEY=
